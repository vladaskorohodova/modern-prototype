    "test:unit": "vitest run",
    "test:e2e": "playwright test tests/e2e/smoke.spec.ts",
    "test:visual": "playwright test tests/e2e/visual.spec.ts",
    "preview": "node scripts/serve-out.mjs",
    "start": "node scripts/serve-out.mjs"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.1.6",
